                        <li>Cost optimization</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Roadmap Section -->
    <section class="roadmap" id="roadmap">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Development Timeline</span>
                <h2>Implementation Roadmap</h2>
            </div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker">1</div>
                    <div class="timeline-content">
                        <h4>Sprint 1: Core UI & Voice (Weeks 1-3)</h4>
                        <p>Chat interface, wake word detection, voice input/output</p>
                        <span class="timeline-deliverable">✓ Working voice assistant prototype</span>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">2</div>
                    <div class="timeline-content">
                        <h4>Sprint 2: Backend APIs (Weeks 4-6)</h4>
                        <p>Garbage, parks, events endpoints with city data integration</p>
                        <span class="timeline-deliverable">✓ Live API connections</span>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">3</div>
                    <div class="timeline-content">
                        <h4>Sprint 3: AI Pipeline (Weeks 7-10)</h4>
                        <p>RAG implementation, vector database, TTS, automated ETL</p>
                        <span class="timeline-deliverable">✓ Intelligent, accurate responses</span>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">4</div>
                    <div class="timeline-content">
                        <h4>Sprint 4: QA & Launch (Weeks 11-13)</h4>
                        <p>Comprehensive testing, monitoring setup, beta launch</p>
                        <span class="timeline-deliverable">✓ Production-ready MVP</span>
                    </div>
                </div>
                <div class="timeline-item future">
                    <div class="timeline-marker">+</div>
                    <div class="timeline-content">
                        <h4>Phase 2: Enhanced Features (Weeks 14+)</h4>
                        <p>Mobile apps, notifications, multi-language, admin dashboard</p>
                        <span class="timeline-deliverable">→ Full-featured platform</span>
                    </div>
                </div>
            </div>
            <div class="roadmap-stats">
                <div class="roadmap-stat">
                    <span class="stat-num">13 weeks</span>
                    <span class="stat-label">to MVP Launch</span>
                </div>
                <div class="roadmap-stat">
                    <span class="stat-num">46 tasks</span>
                    <span class="stat-label">tracked & managed</span>
                </div>
                <div class="roadmap-stat">
                    <span class="stat-num">4 sprints</span>
                    <span class="stat-label">agile development</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Social Proof / Case Studies -->
    <section class="case-studies">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Proven Success</span>
                <h2>Similar Implementations Worldwide</h2>
            </div>
            <div class="case-grid">
                <div class="case-card">
                    <h4>City of Boston - 311 AI Assistant</h4>
                    <p class="case-result">35% reduction in call volume, 92% user satisfaction</p>
                    <p class="case-detail">Deployed in 2022, now handles 15,000+ queries/month across multiple languages.</p>
                </div>
